# PokerClaw config. Copy this to .env if you want to change anything.
#
# Three ways to play, pick one:
#
#   1. RULES (default)    — zero config. Plays vs a deterministic bot.
#   2. FAST-LIVE          — plays vs a real LLM (Anthropic / OpenAI-compatible).
#   3. OPENCLAW-BRIDGE    — plays vs your own OpenClaw agent.
#
# Everything below is optional. Leave it commented and you get rules mode.

# ============================================================================
# Mode 2 (Recommended): FAST-LIVE — uncomment all 4 lines and paste your API key.
# ============================================================================

# POKERCLAW_STRATEGY=fast-live
# POKERCLAW_AGENT_LLM_PROVIDER=anthropic
# POKERCLAW_AGENT_API_KEY=sk-ant-...
# POKERCLAW_AGENT_MODEL=claude-sonnet-4-6

# ============================================================================
# Mode 3: OPENCLAW-BRIDGE — uncomment both lines + create the agent first:
#   openclaw agents add my-poker-bot
#   openclaw agents set-identity --agent my-poker-bot --name "PokerClaw" --emoji "♠️"
# ============================================================================

# POKERCLAW_STRATEGY=openclaw-bridge
# POKERCLAW_BRIDGE_LIVE_AGENT_ID=my-poker-bot

# ============================================================================
# Advanced tuning (optional — sensible defaults applied if unset)
# ============================================================================

# Stack and blind levels for new sessions.
# POKERCLAW_STARTING_STACK=10000
# POKERCLAW_SMALL_BLIND=50
# POKERCLAW_BIG_BLIND=100

# Fast-live tuning. Timeout capped at 5000ms.
# POKERCLAW_FAST_TIMEOUT_MS=5000
# POKERCLAW_FAST_MAX_RETRIES=1

# Use a different (smarter, slower) model for training reviews than for play.
POKERCLAW_REVIEW_MODEL=claude-opus-4-7

# Bridge tuning. The default 180s covers OpenClaw's slow embedded-agent path.
# POKERCLAW_BRIDGE_LIVE_TIMEOUT_SEC=180

# Strict mode: don't fall back to other strategies when the primary fails.
# Useful for verifying your bridge or fast-live setup is actually working.
# POKERCLAW_DISABLE_FALLBACK=1
