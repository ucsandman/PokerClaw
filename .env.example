# PokerClaw local config. Copy to .env if you want to override defaults.

# Express API port (UI dev server proxies /api here).
PORT=3001

# Set to 1 to enable the /api/debug/full-state endpoint. Off by default.
POKERCLAW_DEBUG_FULL_STATE=0

# Starting stack in chips for each new session.
POKERCLAW_STARTING_STACK=10000

# Blinds in chips.
POKERCLAW_SMALL_BLIND=50
POKERCLAW_BIG_BLIND=100

# ---- MoltFire live agent (npm run agent) -----------------------------------
# Set false to keep the agent process exiting immediately on launch.
POKERCLAW_AGENT_ENABLED=true

# match  — production play. No hole cards in logs, ever.
# training — slightly more verbose; still no hole cards.
# debug  — hole cards may appear in logs. Do NOT use when Wes can see the terminal.
POKERCLAW_AGENT_MODE=match

# Poll interval in ms (clamped to 250–5000).
POKERCLAW_AGENT_POLL_MS=750

# Where the agent talks to the dealer.
POKERCLAW_SERVER_URL=http://127.0.0.1:3001

# ---- Strategy selection ---------------------------------------------------
# Top-level strategy chain. Defaults to fast-live so `python poker.py` is
# playable out of the box.
#   fast-live       — direct model call per decision (<=5s timeout).
#   openclaw-bridge — full OpenClaw CLI agent (slow, used for review/tank/identity).
#   rules           — deterministic toy bot, no model.
POKERCLAW_STRATEGY=fast-live

# Fast-live model id override. Leave empty to use POKERCLAW_AGENT_MODEL.
# Recommended: a fast model like `claude-haiku-4-5-20251001` so most spots
# resolve well under the 5s timeout. The slower POKERCLAW_AGENT_MODEL can
# remain set for the legacy llm fallback path.
POKERCLAW_FAST_MODEL=

# Fast-live per-call timeout, clamped to [1000, 5000] ms.
POKERCLAW_FAST_TIMEOUT_MS=5000

# Repair retries when the model returns malformed JSON or an illegal action,
# clamped to [0, 3]. The retry adds a stricter repair note.
POKERCLAW_FAST_MAX_RETRIES=1

# Set to 0 to skip the rule-shortcut layer (which only ever picks `check` on
# trivial low-pressure spots).
POKERCLAW_ENABLE_RULE_SHORTCUTS=1

# ---- LLM strategy ----------------------------------------------------------
# Provider selects which adapter the agent uses for fast-live AND the legacy
# llm fallback in openclaw-bridge mode:
#   anthropic           — Anthropic Messages API (recommended).
#   openai-compatible   — OpenAI /v1/chat/completions (or any compatible URL).
#   off (default)       — no model, rule strategy only.
POKERCLAW_AGENT_LLM_PROVIDER=off

# Required when provider != off. Leave empty to stay on the rule strategy.
POKERCLAW_AGENT_MODEL=
POKERCLAW_AGENT_API_KEY=

# Optional. If unset, defaults to:
#   anthropic         → https://api.anthropic.com/v1/messages
#   openai-compatible → https://api.openai.com/v1/chat/completions
POKERCLAW_AGENT_API_URL=

# LLM call timeout (clamped 1000–30000).
POKERCLAW_AGENT_TIMEOUT_MS=5000

# Example: Anthropic Claude
#   POKERCLAW_AGENT_LLM_PROVIDER=anthropic
#   POKERCLAW_AGENT_MODEL=claude-3-5-sonnet-latest
#   POKERCLAW_AGENT_API_KEY=sk-ant-...
#
# Example: OpenAI
#   POKERCLAW_AGENT_LLM_PROVIDER=openai-compatible
#   POKERCLAW_AGENT_MODEL=gpt-4.1-mini
#   POKERCLAW_AGENT_API_KEY=sk-...

# ---- MoltFire OpenClaw bridge (npm run bridge) -----------------------------
# When true, the agent prefers the OpenClaw bridge sidecar over the direct
# LLM call. The sidecar at bridge/moltfire-bridge.mjs is the *only* thing that
# talks to OpenClaw — PokerClaw never imports OpenClaw internals.
# Strategy chain order when enabled: openclaw-bridge → llm → rules.
POKERCLAW_AGENT_BRIDGE_ENABLED=false

# Where the agent expects the sidecar. MUST be localhost (127.0.0.1, ::1, or
# `localhost`). Non-localhost URLs are rejected at config load.
POKERCLAW_AGENT_BRIDGE_URL=http://127.0.0.1:5179

# Per-decide call timeout, clamped to 1000–60000 ms.
POKERCLAW_AGENT_BRIDGE_TIMEOUT_MS=15000

# Dedicated MoltFire OpenClaw session label. Must NOT collide with Wes's
# primary MoltFire chat session.
POKERCLAW_AGENT_BRIDGE_SESSION_LABEL=moltfire-pokerclaw

# ---- Live MoltFire OpenClaw bridge (sidecar internals) ---------------------
# These vars configure the live dispatch path inside bridge/moltfire-bridge.mjs.
# They are only read by the sidecar (`npm run bridge`), not by the agent.
#
# Dedicated isolated OpenClaw agent that owns the poker session. MUST NOT be
# `main` (or any documented main-agent alias). The bridge hard-refuses to spawn
# against `main`, `default`, `primary`, `moltfire`, or `moltfire-main`.
# One-time setup:
#   openclaw agents add moltfire-poker
#   openclaw agents set-identity moltfire-poker --name "MoltFire (Poker)" --emoji "🔥" --theme red
# Seed the session once with SOUL.md + MOLTFIRE_CONSTITUTION.md + FAIR_PLAY_PROTOCOL.md
# plus the strict JSON output contract from MOLTFIRE_OPENCLAW_BRIDGE.md.
POKERCLAW_BRIDGE_LIVE_AGENT_ID=moltfire-poker

# Optional model override passed through to the CLI. Leave empty to use the
# isolated agent's configured default.
POKERCLAW_BRIDGE_LIVE_MODEL=anthropic/claude-sonnet-4-6

# Per-decide CLI timeout in seconds, clamped to [1, 300]. The sidecar kills the
# child process on expiry and returns 502 so the agent falls back to LLM/rules.
POKERCLAW_BRIDGE_LIVE_TIMEOUT_SEC=30

# Path to the OpenClaw CLI binary. Allowed values:
#   - "openclaw"  (resolved via PATH)
#   - "npx"       (the bridge prepends "openclaw" so it becomes `npx openclaw ...`)
#   - an absolute Windows path (e.g. C:\Tools\openclaw.exe)
#   - an absolute POSIX path (e.g. /usr/local/bin/openclaw)
# Anything else is rejected at config-resolve time. The sidecar spawns the CLI
# WITHOUT shell:true and passes every argument as a separate argv element.
POKERCLAW_BRIDGE_CLI_PATH=openclaw

# ---- Training-session reviewer (Wes-only feature) --------------------------
# When Wes clicks "Review session" the dealer calls a coaching LLM with the
# captured hand snapshots. Uses POKERCLAW_AGENT_API_KEY by default. The model
# override lets you point the reviewer at a stronger reasoning model than the
# live opponent — sonnet is a good default, opus for the deepest reviews.
POKERCLAW_REVIEW_MODEL=
POKERCLAW_REVIEW_API_URL=
POKERCLAW_REVIEW_TIMEOUT_MS=90000
POKERCLAW_REVIEW_MAX_TOKENS=4096
